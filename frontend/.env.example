# Frontend Environment Variables
# Copy this file to .env.local and update the values for your environment

# API Base URL - CRITICAL for production
# Set to your backend API endpoint
# Examples:
#   Development: http://localhost:8000
#   Production: https://api.example.com
VITE_API_URL=http://localhost:8000

# Note: Never commit actual .env files with secrets to version control
# Only commit .env.example files
