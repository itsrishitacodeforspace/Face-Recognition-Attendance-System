# Backend Environment Configuration
# Copy to .env and update values for your environment
#
# ⚠️  SECURITY WARNING:
# Never commit the actual .env file with real secrets to version control!
# Only commit this .env.example file

# ==== CRITICAL SECURITY SETTINGS ====

# Application environment: development, production
# Use 'production' for all deployments
ENVIRONMENT=production

# Debug mode: enable console SQL logs and detailed error messages
# MUST be false in production! Logs can expose sensitive data
DEBUG=false

# Secret key for JWT token signing (CHANGE IN PRODUCTION!)
# Generate a strong random value with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Minimum 32 characters, use secure random value
SECRET_KEY=your-very-secure-secret-key-change-in-production

# ==== DATABASE ====
# SQLite is safe for development/testing only
# Use PostgreSQL or MySQL for production!
# Examples:
#   Development:  sqlite+aiosqlite:///./attendance.db
#   PostgreSQL:   postgresql+asyncpg://user:pass@localhost/dbname
#   MySQL:        mysql+aiomysql://user:pass@localhost/dbname
DATABASE_URL=sqlite+aiosqlite:///./attendance.db

# ==== AUTHENTICATION ====
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Default admin credentials (change immediately after first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-now-please

# ==== CORS SECURITY ====
# Comma-separated list of exact allowed origins
# Examples:
#   Local dev:  http://localhost:5173,http://localhost:3000
#   Production: https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# Regex for dynamic CORS matching (NOT recommended for production)
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?$

# ==== RATE LIMITING ====
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# ==== FACE RECOGNITION ====
RECOGNITION_THRESHOLD=0.6
RECOGNITION_TARGET_CONFIDENCE=0.8
MIN_TRAINING_IMAGES_PER_PERSON=10
MIN_TRAINING_FACE_AREA_RATIO=0.08
MIN_TRAINING_IMAGE_SHARPNESS=80
FACE_DETECTION_THRESHOLD=0.35
INSIGHTFACE_MODEL=buffalo_l
AUTO_TRAIN_ON_UPLOAD=false

# ==== VIDEO PROCESSING ====
VIDEO_SOURCE_TYPE=file
VIDEO_SOURCE_PATH=
FRAME_PROCESS_INTERVAL=1.0
PREVIEW_JPEG_QUALITY=85
PREVIEW_MAX_WIDTH=1280
ATTENDANCE_COOLDOWN_SECONDS=300

# ==== GPU SETTINGS ====
CUDA_ENABLED=true
GPU_STRICT_MODE=false

# ==== UPLOAD LIMITS ====
MAX_IMAGE_UPLOAD_BYTES=5242880
MAX_VIDEO_UPLOAD_BYTES=104857600
MAX_WS_FRAME_BYTES=2097152
